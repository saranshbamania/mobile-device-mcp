    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "jpeg-js": "^0.4.4",
    "pngjs": "^7.0.0",
    "ws": "^8.19.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/jpeg-js": "^0.3.0",
    "@types/node": "^22.0.0",
    "@types/pngjs": "^6.0.5",
    "@types/ws": "^8.18.1",
