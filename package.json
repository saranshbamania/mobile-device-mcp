    "mobile-device-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/saranshbamania/mobile-device-mcp.git"
  },
  "homepage": "https://github.com/saranshbamania/mobile-device-mcp#readme",
